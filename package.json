		"build:nomap": "esbuild source/modules-bundle.js --bundle --format=esm --outfile=public/bundle.js --target=es2017",
		"build:min:nomap": "esbuild source/modules-bundle.js --bundle --format=esm --minify --target=es2017 --outfile=public/bundle.min.js --target=es2017",
		"build:watch": "esbuild source/modules-bundle.js --bundle --format=esm --sourcemap --outfile=public/bundle.js --target=es2017 --watch"
	},
	"devDependencies": {
		"esbuild": "0.27.2"
	}
