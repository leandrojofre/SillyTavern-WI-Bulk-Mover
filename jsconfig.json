{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "baseUrl": "./"
  },
  "typeAcquisition": {
    "enable": true,
    "include": [
      "jquery",
      "toastr"
    ]
  },
  "include": [
    "globals.d.ts",
    "source/**/*.js",
    "index.js"
  ]
}
